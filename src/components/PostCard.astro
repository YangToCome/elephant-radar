---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
  category?: string;
  slug: string;
  heroImage?: string;
  featured?: boolean;
}

const { title, description, pubDate, tags = [], category, slug, heroImage, featured = false } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' });
const year = pubDate.getFullYear();
---

<article class="group relative glass-card overflow-hidden">
  <!-- Featured Badge -->
  {featured && (
    <div class="absolute top-4 right-4 z-10">
      <span class="bg-gradient-to-r from-primary-500 to-purple-500 text-white text-xs font-bold px-3 py-1 rounded-full shadow-lg shadow-primary-500/25">
        置顶
      </span>
    </div>
  )}

  <!-- Image -->
  {heroImage ? (
    <div class="relative h-48 overflow-hidden rounded-t-2xl">
      <img src={heroImage} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
      {category && (
        <span class="absolute bottom-3 left-3 glass px-3 py-1 rounded-full text-xs font-medium text-white">
          {category}
        </span>
      )}
    </div>
  ) : (
    <div class="relative h-48 overflow-hidden rounded-t-2xl bg-gradient-to-br from-primary-500/20 via-purple-500/20 to-pink-500/20">
      <div class="absolute inset-0 flex items-center justify-center">
        <svg class="w-16 h-16 text-primary-500/30 group-hover:text-primary-500/50 transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
        </svg>
      </div>
      {category && (
        <span class="absolute bottom-3 left-3 glass px-3 py-1 rounded-full text-xs font-medium text-primary-300">
          {category}
        </span>
      )}
    </div>
  )}

  <!-- Content -->
  <div class="p-6">
    <div class="flex items-center gap-2 text-xs text-surface-400 mb-3">
      <time datetime={pubDate.toISOString()}>{year}年{formattedDate}</time>
    </div>
    
    <h3 class="text-lg font-bold text-surface-800 dark:text-white mb-2 group-hover:text-primary-500 transition-colors line-clamp-2">
      <a href={`/blog/${slug}`} class="hover:underline decoration-primary-500/30">
        {title}
      </a>
    </h3>
    
    <p class="text-sm text-surface-500 dark:text-surface-400 line-clamp-2 leading-relaxed mb-4">
      {description}
    </p>
    
    <!-- Tags -->
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {tags.slice(0, 3).map((tag) => (
          <span class="text-xs px-2 py-0.5 rounded-md bg-primary-500/10 text-primary-600 dark:text-primary-400">
            #{tag}
          </span>
        ))}
        {tags.length > 3 && (
          <span class="text-xs px-2 py-0.5 rounded-md bg-surface-200/50 dark:bg-surface-700/50 text-surface-400">
            +{tags.length - 3}
          </span>
        )}
      </div>
    )}
  </div>
</article>
