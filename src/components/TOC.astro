<aside class="glass-card p-6">
  <h3 class="text-sm font-semibold text-surface-700 dark:text-surface-200 mb-4 flex items-center gap-2">
    <svg class="w-4 h-4 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
    </svg>
    目录
  </h3>
  <nav id="toc-nav" class="space-y-1 text-sm max-h-[60vh] overflow-y-auto">
    <!-- TOC items will be populated by client script -->
  </nav>
</aside>

<script>
  function buildTOC() {
    const article = document.querySelector('.prose-custom');
    const tocNav = document.getElementById('toc-nav');
    if (!article || !tocNav) return;

    const headings = article.querySelectorAll('h2, h3');
    if (headings.length === 0) {
      tocNav.innerHTML = '<p class="text-surface-400 text-xs">暂无目录</p>';
      return;
    }

    tocNav.innerHTML = '';
    headings.forEach((heading) => {
      const level = heading.tagName === 'H2' ? 2 : 3;
      const id = heading.id || heading.textContent?.trim().replace(/\s+/g, '-').toLowerCase() || '';
      heading.id = id;

      const link = document.createElement('a');
      link.href = `#${id}`;
      link.textContent = heading.textContent;
      link.className = level === 2
        ? 'block py-1.5 text-surface-500 dark:text-surface-400 hover:text-primary-500 dark:hover:text-primary-400 transition-colors border-l-2 border-transparent hover:border-primary-500 pl-3'
        : 'block py-1 text-surface-400 dark:text-surface-500 hover:text-primary-500 dark:hover:text-primary-400 transition-colors border-l-2 border-transparent hover:border-primary-500/50 pl-6 text-xs';
      
      link.addEventListener('click', (e) => {
        e.preventDefault();
        document.getElementById(id)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });

      tocNav.appendChild(link);
    });

    // Active heading tracking
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const link = tocNav.querySelector(`a[href="#${entry.target.id}"]`);
          if (entry.isIntersecting) {
            tocNav.querySelectorAll('a').forEach((a) => a.classList.remove('text-primary-500', 'dark:text-primary-400', 'border-primary-500'));
            link?.classList.add('text-primary-500', 'dark:text-primary-400', 'border-primary-500');
          }
        });
      },
      { rootMargin: '-20% 0px -80% 0px' }
    );

    headings.forEach((heading) => observer.observe(heading));
  }

  // Build TOC after page load
  document.addEventListener('DOMContentLoaded', buildTOC);
  // Also build on Astro page transitions
  document.addEventListener('astro:page-load', buildTOC);
</script>
