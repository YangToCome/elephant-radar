---
interface Props {
  tag: string;
  count?: number;
  active?: boolean;
}

const { tag, count, active = false } = Astro.props;
---

<a href={`/tags/${tag}`} class:list={[
  'inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium transition-all duration-200',
  active 
    ? 'bg-primary-500 text-white shadow-lg shadow-primary-500/25' 
    : 'bg-primary-500/10 text-primary-600 dark:text-primary-400 hover:bg-primary-500/20 hover:shadow-md hover:shadow-primary-500/10'
]}>
  #{tag}
  {count !== undefined && (
    <span class:list={[
      'text-xs px-1.5 py-0.5 rounded-full',
      active ? 'bg-white/20' : 'bg-primary-500/10'
    ]}>{count}</span>
  )}
</a>
