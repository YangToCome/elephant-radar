---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PostCard from "../components/PostCard.astro";
import TagBadge from "../components/TagBadge.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featuredPosts = sortedPosts.filter((post) => post.data.featured);
const recentPosts = sortedPosts.slice(0, 6);

const allTags = [...new Set(sortedPosts.flatMap((post) => post.data.tags))];
const allCategories = [
  ...new Set(sortedPosts.map((post) => post.data.category)),
];
---

<BaseLayout
  title="Elephant Radar"
  description="2026的一个晚上在虎鲸宿舍创建-Yang的博客"
>
  <Header />

  <!-- Hero Section -->
  <section class="hero-gradient min-h-screen flex items-center relative overflow-hidden">
    <!-- Animated background orbs -->
    <div class="absolute top-[10%] left-[5%] w-72 h-72 bg-primary-500/20 rounded-full blur-[120px] animate-float"></div>
    <div class="absolute top-[30%] right-[10%] w-96 h-96 bg-purple-500/15 rounded-full blur-[150px] animate-float-delay"></div>
    <div class="absolute bottom-[10%] left-[30%] w-80 h-80 bg-pink-500/10 rounded-full blur-[130px] animate-float-slow"></div>
    <div class="absolute top-[60%] right-[30%] w-64 h-64 bg-indigo-500/15 rounded-full blur-[100px] animate-float"></div>

    <!-- Grid pattern overlay -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(99,102,241,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(99,102,241,0.03)_1px,transparent_1px)] bg-[size:64px_64px]"></div>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10 py-32">
      <div class="max-w-4xl">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 glass px-4 py-2 rounded-full mb-8 animate-fade-in">
          <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
          <span class="text-sm text-surface-300">持续更新</span>
        </div>

        <!-- Title -->
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-white mb-6 text-balance leading-tight animate-slide-up">
          探索技术的<br />
          <span class="bg-gradient-to-r from-primary-400 via-purple-400 to-pink-400 bg-clip-text text-transparent bg-200% animate-gradient">
            无限可能
          </span>
        </h1>

        <!-- Subtitle -->
        <p class="text-xl sm:text-2xl text-surface-300/80 mb-12 max-w-2xl leading-relaxed animate-fade-in" style="animation-delay: 0.3s">
          记录思考与实践
        </p>

        <!-- CTA -->
        <div class="flex flex-wrap gap-4 animate-fade-in" style="animation-delay: 0.5s">
          <a href="/blog" class="group inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-primary-500 to-purple-600 text-white font-semibold rounded-2xl shadow-lg shadow-primary-500/25 hover:shadow-primary-500/40 hover:scale-105 transition-all duration-300">
            浏览文章
            <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </a>
          <a href="/about" class="inline-flex items-center gap-2 px-8 py-4 glass text-white font-semibold rounded-2xl hover:bg-white/20 transition-all duration-300">
            了解更多
          </a>
        </div>

        <!-- Stats -->
        <div class="flex flex-wrap gap-8 mt-16 animate-fade-in" style="animation-delay: 0.7s">
          <div class="text-center">
            <div class="text-3xl font-bold text-white">{sortedPosts.length}</div>
            <div class="text-sm text-surface-400 mt-1">文章</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white">{allTags.length}</div>
            <div class="text-sm text-surface-400 mt-1">标签</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white">{allCategories.length}</div>
            <div class="text-sm text-surface-400 mt-1">分类</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-surface-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </div>
  </section>

  <!-- Featured Posts -->
  {featuredPosts.length > 0 && (
    <section class="container mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="flex items-center justify-between mb-12">
        <div>
          <h2 class="text-3xl font-bold text-surface-800 dark:text-white">精选文章</h2>
          <p class="text-surface-500 mt-2">值得深入阅读的深度内容</p>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {featuredPosts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            category={post.data.category}
            slug={post.slug}
            heroImage={post.data.heroImage}
            featured={post.data.featured}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Recent Posts -->
  <section class="container mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="flex items-center justify-between mb-12">
      <div>
        <h2 class="text-3xl font-bold text-surface-800 dark:text-white">最新文章</h2>
        <p class="text-surface-500 mt-2">最近发布的技术内容</p>
      </div>
      <a href="/blog" class="hidden sm:flex items-center gap-2 text-primary-500 hover:text-primary-400 font-medium transition-colors">
        查看全部
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {recentPosts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
          category={post.data.category}
          slug={post.slug}
          heroImage={post.data.heroImage}
        />
      ))}
    </div>
  </section>

  <!-- Tags Section -->
  {allTags.length > 0 && (
    <section class="container mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="glass-card p-10">
        <h2 class="text-2xl font-bold text-surface-800 dark:text-white mb-6">热门标签</h2>
        <div class="flex flex-wrap gap-3">
          {allTags.map((tag) => (
            <TagBadge tag={tag} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="container mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="relative overflow-hidden rounded-3xl bg-gradient-to-r from-primary-600 via-purple-600 to-pink-600 p-12 sm:p-16 text-center">
      <div class="absolute top-0 left-0 w-full h-full bg-[linear-gradient(rgba(255,255,255,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.05)_1px,transparent_1px)] bg-[size:32px_32px]"></div>
      <div class="relative z-10">
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">开始你的技术之旅</h2>
        <p class="text-lg text-white/70 mb-8 max-w-xl mx-auto">持续输出高质量内容，一路相伴</p>
        <a href="/blog" class="inline-flex items-center gap-2 px-8 py-4 bg-white text-primary-600 font-bold rounded-2xl hover:bg-white/90 hover:scale-105 transition-all duration-300 shadow-lg">
          浏览全部文章
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
